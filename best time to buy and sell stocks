class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int mini=prices[0];
        int n=prices.size();
        int profit=0;
        //buy low and sell high
        for(int i=1;i<n;i++){
            int transfer=prices[i]-mini;
            profit=max(profit,transfer);
            mini=min(mini,prices[i]);
        }
        return profit;
    }
